CREATE TABLE users (
  id SERIAL PRIMARY KEY,
  name TEXT,
  email TEXT UNIQUE,
  password TEXT
);

CREATE TABLE trips (
  id SERIAL PRIMARY KEY,
  user_id INT REFERENCES users(id),
  title TEXT,
  description TEXT,
  start_date DATE,
  end_date DATE
);

CREATE TABLE stops (
  id SERIAL PRIMARY KEY,
  trip_id INT REFERENCES trips(id),
  city TEXT,
